# ======================================================
# Mentorque Backend — Environment Variables
# Copy this file to .env and fill in your values
# ======================================================

# PostgreSQL connection string (NeonDB / Supabase)
DATABASE_URL=postgresql://username:password@host:5432/dbname?sslmode=require

# JWT auth secret (generate a strong random string)
JWT_SECRET=your-super-secure-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# Server
PORT=5000

# CORS — your frontend URL
CORS_ORIGIN=http://localhost:5173

# ======================================================
# AI Recommendation (Google Gemini - FREE)
# Get your key at: https://aistudio.google.com/app/apikey
# ======================================================
GEMINI_API_KEY=your-gemini-api-key-here

# ======================================================
# Optional: Google Calendar (for Meet link generation)
# Leave empty to skip — meet links will be null
# ======================================================
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=
# GOOGLE_REFRESH_TOKEN=
